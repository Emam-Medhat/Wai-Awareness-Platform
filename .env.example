APP_NAME="منصة وعي"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_TIMEZONE=Asia/Riyadh
APP_URL=http://localhost:8001

APP_LOCALE=ar
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=ar_SA

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=wa3y_mysql
DB_PORT=3306
DB_DATABASE=wa3y_db
DB_USERNAME=wa3y_user
DB_PASSWORD=wa3y_password

SESSION_DRIVER=redis
SESSION_LIFETIME=120

QUEUE_CONNECTION=redis
REDIS_HOST=wa3y_redis
REDIS_PASSWORD=null
REDIS_PORT=6379

CACHE_STORE=redis
CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

FILESYSTEM_DISK=local
FILESYSTEM_CLOUD=s3

# Mail Configuration
MAIL_MAILER=smtp
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="noreply@wa3y.gov.sa"
MAIL_FROM_NAME="${APP_NAME}"

# AI Assistant Configuration
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-3.5-turbo

# SMS Configuration
SMS_DRIVER=log
TWILLO_SID=null
TWILLO_TOKEN=null
TWILLO_FROM=null

# Social Login
GOOGLE_CLIENT_ID=null
GOOGLE_CLIENT_SECRET=null
GOOGLE_REDIRECT_URL=null

# Analytics
GOOGLE_ANALYTICS_ID=null
FACEBOOK_PIXEL_ID=null

VITE_APP_NAME="${APP_NAME}"
