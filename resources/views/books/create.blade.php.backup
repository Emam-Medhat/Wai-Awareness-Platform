            <button type="submit" class="btn btn-submit btn-lg me-3">
              <i class="bi bi-check-circle me-2"></i>
              نشر الكتاب
            </button>
            <a href="{{ route('books.index') }}" class="btn btn-cancel btn-lg">
              <i class="bi bi-x-circle me-2"></i>
              إلغاء
            </a>
