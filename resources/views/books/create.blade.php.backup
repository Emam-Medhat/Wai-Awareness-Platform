{{-- JavaScript for File Preview --}}
<script>
function previewFile(input, type) {
  const preview = document.getElementById(type + '-preview');
  const file = input.files[0];
  
  if (file) {
    const reader = new FileReader();
    reader.onload = function(e) {
      if (type === 'cover') {
        preview.innerHTML = `<img src="${e.target.result}" class="preview-image" alt="Preview">`;
      } else {
        preview.innerHTML = `<div class="preview-file"><i class="bi bi-file-pdf"></i><span>${file.name}</span></div>`;
      }
    };
    reader.readAsDataURL(file);
  }
}

// Form validation and debugging
document.addEventListener('DOMContentLoaded', function() {
  console.log('🚀 DOM loaded, setting up form...');
  
  const form = document.getElementById('addBookForm');
  if (!form) {
    console.error('❌ Form not found!');
    alert('خطأ: لم يتم العثور على النموذج');
    return;
  }
  
  console.log('✅ Form found:', form);
  console.log('Form action:', form.action);
  console.log('Form method:', form.method);
  
  // Check CSRF token
  const csrfToken = form.querySelector('input[name="_token"]');
  if (csrfToken) {
    console.log('✅ CSRF token found');
  } else {
    console.error('❌ CSRF token missing!');
  }
  
  form.addEventListener('submit', function(e) {
    console.log('🚀 === FORM SUBMISSION STARTED ===');
    console.log('Event type:', e.type);
    console.log('Form action:', form.action);
    console.log('Form method:', form.method);
    
    e.preventDefault(); // Always prevent first to check everything
    console.log('⏸️ Submission prevented for validation...');
    
    const requiredFields = form.querySelectorAll('[required]');
    let isValid = true;
    let missingFields = [];
    let validationErrors = [];
    
    console.log('📋 Required fields found:', requiredFields.length);
    
    // Validate each required field
    requiredFields.forEach((field, index) => {
      console.log(`--- Field ${index + 1}: ${field.name} ---`);
      console.log('Type:', field.type);
      console.log('Required:', field.required);
      
      // Remove previous error styling
      field.classList.remove('is-invalid');
      
      // Special handling for file inputs
      if (field.type === 'file') {
        if (!field.files || field.files.length === 0) {
          console.log('❌ Missing file:', field.name);
          field.classList.add('is-invalid');
          isValid = false;
          missingFields.push(field.name);
          validationErrors.push(`ملف ${field.name} مطلوب`);
        } else {
          console.log('✅ File found:', field.name, field.files[0].name);
          // Check file size
          const maxSize = field.name === 'cover_image' ? 5 * 1024 * 1024 : 50 * 1024 * 1024; // 5MB for image, 50MB for PDF
          if (field.files[0].size > maxSize) {
            console.log('❌ File too large:', field.name, field.files[0].size);
            field.classList.add('is-invalid');
            isValid = false;
            validationErrors.push(`حجم ملف ${field.name} كبير جداً`);
          }
        }
      } else {
        const value = field.value.trim();
        if (!value) {
          console.log('❌ Empty field:', field.name);
          field.classList.add('is-invalid');
          isValid = false;
          missingFields.push(field.name);
          validationErrors.push(`حقل ${field.name} مطلوب`);
        } else {
          console.log('✅ Field filled:', field.name, value.substring(0, 50) + (value.length > 50 ? '...' : ''));
          
          // Additional validation for specific fields
          if (field.name === 'title' && value.length < 3) {
            field.classList.add('is-invalid');
            isValid = false;
            validationErrors.push('عنوان الكتاب يجب أن يكون 3 أحرف على الأقل');
          }
          
          if (field.name === 'description' && value.length < 10) {
            field.classList.add('is-invalid');
            isValid = false;
            validationErrors.push('وصف الكتاب يجب أن يكون 10 أحرف على الأقل');
          }
          
          if (field.name === 'content' && value.length < 50) {
            field.classList.add('is-invalid');
            isValid = false;
            validationErrors.push('محتوى الكتاب يجب أن يكون 50 حرف على الأقل');
          }
        }
      }
    });
    
    console.log('=== VALIDATION RESULTS ===');
    console.log('Form valid:', isValid);
    console.log('Missing fields:', missingFields);
    console.log('Validation errors:', validationErrors);
    
    if (!isValid) {
      console.log('❌ FORM HAS ERRORS - SHOWING ALERT');
      const errorMessage = validationErrors.length > 0 
        ? validationErrors.join('\n')
        : 'يرجى ملء جميع الحقول المطلوبة:\n' + missingFields.join('\n');
      
      alert('❌ أخطاء في النموذج:\n\n' + errorMessage);
      return false;
    }
    
    // If we reach here, form is valid
    console.log('✅ FORM IS VALID - SUBMITTING...');
    
    // Create FormData and log all data
    const formData = new FormData(form);
    console.log('📤 Form data being submitted:');
    for (let [key, value] of formData.entries()) {
      if (value instanceof File) {
        console.log(`  ${key}: [File] ${value.name} (${value.size} bytes)`);
      } else {
        console.log(`  ${key}: ${value}`);
      }
    }
    
    // Submit using fetch to see exactly what happens
    fetch(form.action, {
      method: form.method,
      body: formData,
      headers: {
        'X-Requested-With': 'XMLHttpRequest',
        'Accept': 'application/json'
      }
    })
    .then(response => {
      console.log('📡 Response received:', response);
      if (response.ok) {
        console.log('✅ Response OK');
        return response.json();
      } else {
        console.log('❌ Response error:', response.status, response.statusText);
        return response.text().then(text => {
          console.log('Error response body:', text);
          throw new Error(`HTTP ${response.status}: ${text}`);
        });
      }
    })
    .then(data => {
      console.log('✅ Success response:', data);
      if (data.redirect) {
        window.location.href = data.redirect;
      } else {
        alert('✅ تم إضافة الكتاب بنجاح!');
        window.location.reload();
      }
    })
    .catch(error => {
      console.error('❌ Submission error:', error);
      alert('❌ حدث خطأ أثناء إرسال النموذج:\n\n' + error.message);
    });
    
    return false; // Prevent default form submission
  });
  
  // Also add click debugging
  const submitBtn = form.querySelector('button[type="submit"]');
  if (submitBtn) {
    console.log('✅ Submit button found:', submitBtn);
    submitBtn.addEventListener('click', function(e) {
      console.log('🖱️ Submit button clicked!');
      console.log('Click event:', e);
    });
  } else {
    console.error('❌ Submit button not found!');
  }
  
  // Add real-time validation
  const requiredInputs = form.querySelectorAll('input[required], textarea[required], select[required]');
  requiredInputs.forEach(input => {
    input.addEventListener('blur', function() {
      if (!this.value.trim()) {
        this.classList.add('is-invalid');
      } else {
        this.classList.remove('is-invalid');
      }
    });
  });
});
</script>

              <div class="col-md-6">
                <div class="form-check">
                  <input type="checkbox" name="featured" class="form-check-input" 
                         id="featured" value="1">
                  <label class="form-check-label" for="featured">
                    عرض الكتاب في قسم الكتب المميزة
                  </label>
                </div>
              </div>

              <div class="col-md-6">
